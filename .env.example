# ========== Telegram ==========
# Bot Token（从 @BotFather 获取）
TG_TOKEN=

# 授权聊天 ID（支持逗号分隔多个，私聊为正数，群组/频道为负数）
# 示例：123456789 或 123456789,-100987654321
TG_CHAT_ID=

# ========== 数据库 ==========
DATABASE_PATH=./data/data.db

# ========== Cloudflare R2 同步（可选） ==========
# 不填则跳过 R2 同步，数据仅存本地
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# R2 中存储的文件名，默认 rooms.json
# R2_KEY=rooms.json

# ========== Web 面板（可选） ==========
# 不填则不启动 Web 服务，填写端口号后启用面板和健康检查
# PORT=8000

# ========== FFmpeg（可选） ==========
# 不填则使用系统 PATH 中的 ffmpeg
# FFMPEG_PATH=/usr/bin/ffmpeg
