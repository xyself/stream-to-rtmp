# ========== Telegram ==========
# Bot Token（从 @BotFather 获取）
TG_TOKEN=

# 授权聊天 ID（支持逗号分隔多个，私聊为正数，群组/频道为负数）
# 示例：123456789 或 123456789,-100987654321
TG_CHAT_ID=

# ========== 数据库 ==========
DATABASE_PATH=./data/data.db

# ========== GitHub Gist 同步（可选） ==========
# 不填则跳过同步，数据仅存本地
# GIST_TOKEN: GitHub Personal Access Token（需要 gist scope）
# GIST_ID: Gist 的 ID（URL 中最后一段）
GIST_TOKEN=
GIST_ID=

# ========== Web 面板（可选） ==========
# 不填则不启动 Web 服务，填写端口号后启用面板和健康检查
# PORT=8080

# ========== FFmpeg（可选） ==========
# 不填则使用系统 PATH 中的 ffmpeg
# FFMPEG_PATH=/usr/bin/ffmpeg
